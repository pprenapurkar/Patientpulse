# ═══════════════════════════════════════════════════════════════
# PatientPulse — Environment Variables
# ═══════════════════════════════════════════════════════════════
# STEP 1: Copy this file:  cp .env.example .env
# STEP 2: Set your Anthropic API key (only required change)
# STEP 3: Run: cd infra && docker compose up -d
# ═══════════════════════════════════════════════════════════════

# ─── AI (REQUIRED — get from console.anthropic.com) ───────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Auth tokens (demo hardcoded tokens — DO NOT CHANGE) ──────
# These exact values are what the backend validates.
# Change them only if you update validate_token() in security.py
CLINICIAN_TOKEN=demo-clinician-token
PATIENT_TOKEN=demo-patient-token

# ─── Patient ID (auto-set by seed_fhir.sh — leave as-is) ──────
PATIENT_ID=maria-chen-uuid

# ─── FHIR (uses Docker internal hostname) ─────────────────────
HAPI_FHIR_BASE_URL=http://hapi-fhir:8080/fhir

# ─── Database ─────────────────────────────────────────────────
POSTGRES_URL=postgresql://hapi:hapipassword@postgres:5432/hapi
POSTGRES_PASSWORD=hapipassword

# ─── Cache ────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@redis:6379/0
REDIS_PASSWORD=redispassword

# ─── App ──────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Frontend (URL browser uses to reach the backend) ─────────
# For local: keep as http://localhost:8000
# For cloud: change to https://your-backend-domain.com
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_ENV=development
